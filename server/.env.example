# Copy this file to .env and fill in real values. Never commit .env.

# MongoDB Atlas connection string (Database > Connect > Drivers in the Atlas UI).
# Must include a database name, e.g. .../smaatech_hrms?retryWrites=true&w=majority
MONGODB_URI=

PORT=4000

# Generate strong random values, e.g.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Origin the frontend dev server runs on, for CORS + cookie settings.
CLIENT_ORIGIN=http://localhost:5173

# Reverse geocoding (check-in address) uses OpenStreetMap's free Nominatim
# service — no API key needed, nothing to configure here.

# Gmail SMTP for real password-reset OTP emails. Generate an App Password at
# myaccount.google.com/apppasswords (needs 2-Step Verification enabled on
# that Google account first) — NOT your normal Gmail password.
SMTP_USER=
SMTP_PASS=
