# Copy this file to .env and fill in real values. Never commit .env.
# Not needed for local dev (the Vite dev proxy handles /api automatically —
# see vite.config.js). Only required for a production build (Vercel), where
# the client and server run on different domains.

# The deployed server's API base URL, e.g. https://smaatech-hrms-api.onrender.com/api/v1
VITE_API_BASE_URL=
